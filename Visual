-- Spawn initial enemies (grid)
local function spawnEnemies()
    for _, e in ipairs(enemies) do e:Destroy() end
    enemies = {}
    local rows = 3
    local cols = 5
    local startX = 40
    local startY = 30
    local spacingX = 45
    local spacingY = 40
    for row = 1, rows do
        for col = 1, cols do
            local x = startX + (col-1)*spacingX
            local y = startY + (row-1)*spacingY
            table.insert(enemies, createEnemy(x, y))
        end
    end
end

-- Create bullet
local function shoot()
    if not gameActive or shootCooldown then return end
    shootCooldown = true
    task.delay(0.3, function() shootCooldown = false end)
    
    local bullet = Instance.new("Frame")
    bullet.Size = UDim2.new(0, 3, 0, 8)
    bullet.BackgroundColor3 = Color3.fromRGB(0, 255, 100)
    bullet.BorderSizePixel = 0
    bullet.ZIndex = 4
    bullet.Parent = Canvas
    Instance.new("UICorner", bullet).CornerRadius = UDim.new(1, 0)
    
    local playerAbsPos = player.AbsolutePosition
    local canvasAbsPos = Canvas.AbsolutePosition
    local x = playerAbsPos.X - canvasAbsPos.X + player.AbsoluteSize.X/2 - 1.5
    local y = playerAbsPos.Y - canvasAbsPos.Y - 5
    bullet.Position = UDim2.new(0, x, 0, y)
    
    table.insert(bullets, bullet)
end

-- Update game state
local function updateGame(dt)
    if not gameActive or not player then return end
    
    -- Move player based on touch/button input (handled separately)
    local canvasAbs = Canvas.AbsoluteSize
    local minX = 10
    local maxX = canvasAbs.X - player.AbsoluteSize.X - 10
    local currentX = player.AbsolutePosition.X - Canvas.AbsolutePosition.X
    local newX = currentX + (moveLeft and -playerSpeed*dt or moveRight and playerSpeed*dt or 0)
    newX = math.clamp(newX, minX, maxX)
    player.Position = UDim2.new(0, newX, 1, -30)
    playerPosX = newX / canvasAbs.X
    
    -- Move bullets
    for i = #bullets, 1, -1 do
        local b = bullets[i]
        if not b.Parent then table.remove(bullets, i) continue end
        local y = b.Position.Y.Offset - bulletSpeed * dt
        if y < -20 then
            b:Destroy()
            table.remove(bullets, i)
        else
            b.Position = UDim2.new(0, b.Position.X.Offset, 0, y)
        end
    end
    
    -- Move enemies (simple left-right bounce)
    local enemyMoveX = 0
    local edgeHit = false
    for _, e in ipairs(enemies) do
        local x = e.Position.X.Offset
        if x < 10 or x > Canvas.AbsoluteSize.X - e.AbsoluteSize.X - 10 then
            edgeHit = true
        end
    end
    if edgeHit then
        for _, e in ipairs(enemies) do
            local y = e.Position.Y.Offset + 15
            e.Position = UDim2.new(0, e.Position.X.Offset, 0, y)
        end
        enemyMoveX = -enemyMoveX
    else
        enemyMoveX = (math.sin(tick()*2) > 0 and 30 or -30) * dt
    end
    
    for _, e in ipairs(enemies) do
        local x = e.Position.X.Offset + enemyMoveX
        x = math.clamp(x, 10, Canvas.AbsoluteSize.X - e.AbsoluteSize.X - 10)
        e.Position = UDim2.new(0, x, 0, e.Position.Y.Offset)
    end
    
    -- Collisions: bullets vs enemies
    for i = #bullets, 1, -1 do
        local b = bullets[i]
        local bPos = b.Position
        local bAbsPos = b.AbsolutePosition
        local hit = false
        for j = #enemies, 1, -1 do
            local e = enemies[j]
            if e and e.Parent then
                local eAbsPos = e.AbsolutePosition
                if math.abs(bAbsPos.X - eAbsPos.X) < e.AbsoluteSize.X/2 + b.AbsoluteSize.X/2 and
                   math.abs(bAbsPos.Y - eAbsPos.Y) < e.AbsoluteSize.Y/2 + b.AbsoluteSize.Y/2 then
                    e:Destroy()
                    table.remove(enemies, j)
                    b:Destroy()
                    table.remove(bullets, i)
                    score = score + 10
                    ScoreLabel.Text = "SCORE: " .. score
                    hit = true
                    break
                end
            end
        end
        if hit then continue end
    end
    
    -- Enemy vs player collision
    for _, e in ipairs(enemies) do
        local eAbs = e.AbsolutePosition
        local pAbs = player.AbsolutePosition
        if math.abs(eAbs.X - pAbs.X) < player.AbsoluteSize.X and
           math.abs(eAbs.Y - pAbs.Y) < player.AbsoluteSize.Y then
            lives = lives - 1
            LivesLabel.Text = "LIVES: " .. lives
            if lives <= 0 then
                gameActive = false
                player:Destroy()
                player = nil
                for _, b in ipairs(bullets) do b:Destroy() end
                bullets = {}
                for _, e in ipairs(enemies) do e:Destroy() end
                enemies = {}
                local gameOverText = Instance.new("TextLabel")
                gameOverText.Size = UDim2.new(1, 0, 1, 0)
                gameOverText.BackgroundTransparency = 1
                gameOverText.Text = "GAME OVER\nTap to restart"
                gameOverText.TextColor3 = Color3.fromRGB(255, 100, 100)
                gameOverText.TextSize = 18
                gameOverText.Font = Enum.Font.GothamBold
                gameOverText.TextWrapped = true
                gameOverText.ZIndex = 5
                gameOverText.Parent = Canvas
                local function restart()
                    gameOverText:Destroy()
                    gameActive = true
                    lives = 3
                    score = 0
                    LivesLabel.Text = "LIVES: 3"
                    ScoreLabel.Text = "SCORE: 0"
                    createPlayer()
                    spawnEnemies()
                end
                gameOverText.InputBegan:Connect(function(input)
                    if input.UserInputType == Enum.UserInputType.Touch or input.UserInputType == Enum.UserInputType.MouseButton1 then
                        restart()
                    end
                end)
            else
                -- Respawn player and reset enemies
                if player then player:Destroy() end
                createPlayer()
                -- Remove all enemies and spawn new wave
                for _, e in ipairs(enemies) do e:Destroy() end
                enemies = {}
                spawnEnemies()
                for _, b in ipairs(bullets) do b:Destroy() end
                bullets = {}
            end
            break
        end
    end
    
    -- If all enemies destroyed, spawn new wave
    if #enemies == 0 and gameActive then
        spawnEnemies()
    end
end

