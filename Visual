-- Create pipe pair
local function createPipePair()
    local canvasAbs = Canvas.AbsoluteSize
    if canvasAbs.Y == 0 then return end
    
    local minGapY = 50
    local maxGapY = canvasAbs.Y - pipeGap - 50
    local gapY = math.random(minGapY, maxGapY)
    
    local pipeGroup = {}
    
    -- Top pipe
    local topPipe = Instance.new("Frame")
    topPipe.Size = UDim2.new(0, pipeWidth, 0, gapY)
    topPipe.Position = UDim2.new(1, 0, 0, 0)
    topPipe.BackgroundColor3 = Color3.fromRGB(50, 150, 50)
    topPipe.BorderSizePixel = 0
    topPipe.ZIndex = 3
    topPipe.Parent = Canvas
    Instance.new("UICorner", topPipe).CornerRadius = UDim.new(0, 2)
    
    local topGlow = Instance.new("Frame")
    topGlow.Size = UDim2.new(1, 2, 1, 0)
    topGlow.Position = UDim2.new(0, -1, 0, 0)
    topGlow.BackgroundColor3 = Color3.fromRGB(100, 255, 100)
    topGlow.BackgroundTransparency = 0.5
    topGlow.BorderSizePixel = 0
    topGlow.ZIndex = 2
    topGlow.Parent = topPipe
    
    -- Bottom pipe
    local bottomPipe = Instance.new("Frame")
    local bottomHeight = canvasAbs.Y - gapY - pipeGap
    bottomPipe.Size = UDim2.new(0, pipeWidth, 0, bottomHeight)
    bottomPipe.Position = UDim2.new(1, 0, 0, gapY + pipeGap)
    bottomPipe.BackgroundColor3 = Color3.fromRGB(50, 150, 50)
    bottomPipe.BorderSizePixel = 0
    bottomPipe.ZIndex = 3
    bottomPipe.Parent = Canvas
    Instance.new("UICorner", bottomPipe).CornerRadius = UDim.new(0, 2)
    
    local bottomGlow = Instance.new("Frame")
    bottomGlow.Size = UDim2.new(1, 2, 1, 0)
    bottomGlow.Position = UDim2.new(0, -1, 0, 0)
    bottomGlow.BackgroundColor3 = Color3.fromRGB(100, 255, 100)
    bottomGlow.BackgroundTransparency = 0.5
    bottomGlow.BorderSizePixel = 0
    bottomGlow.ZIndex = 2
    bottomGlow.Parent = bottomPipe
    
    table.insert(pipes, {
        top = topPipe,
        bottom = bottomPipe,
        x = Canvas.AbsoluteSize.X,
        passed = false
    })
end

-- Reset game
local function resetGame()
    gameActive = true
    score = 0
    ScoreLabel.Text = "SCORE: 0"
    
    -- Clear pipes
    for _, pipe in ipairs(pipes) do
        if pipe.top then pipe.top:Destroy() end
        if pipe.bottom then pipe.bottom:Destroy() end
    end
    pipes = {}
    
    -- Reset bird
    createBird()
    pipeSpawnTimer = 0.5 -- Small delay before first pipe
end

-- Jump function
local function flap()
    if not gameActive then
        resetGame()
        return
    end
    birdVelocity = jumpForce
    
    -- Add visual feedback
    if bird then
        local originalColor = bird.BackgroundColor3
        bird.BackgroundColor3 = Color3.fromRGB(255, 255, 100)
        task.delay(0.1, function()
            if bird then bird.BackgroundColor3 = originalColor end
        end)
    end
end

-- Update game
local function updateGame(dt)
    if not gameActive or not bird or not bird.Parent then return end
    
    local canvasAbs = Canvas.AbsoluteSize
    if canvasAbs.Y == 0 then return end
    
    -- Apply gravity
    birdVelocity = birdVelocity + gravity * dt
    local birdY = bird.Position.Y.Offset + birdVelocity * dt
    
    -- Boundaries
    local minY = 5
    local maxY = canvasAbs.Y - bird.AbsoluteSize.Y - 5
    if birdY < minY then
        birdY = minY
        birdVelocity = 0
        gameActive = false
    elseif birdY > maxY then
        birdY = maxY
        birdVelocity = 0
        gameActive = false
    end
    
    bird.Position = UDim2.new(0.5, -10, 0, birdY)
    
    -- Spawn pipes
    pipeSpawnTimer = pipeSpawnTimer + dt
    if pipeSpawnTimer >= pipeSpawnInterval and gameActive then
        pipeSpawnTimer = 0
        createPipePair()
    end
    
    -- Move pipes and check collisions
    for i = #pipes, 1, -1 do
        local pipe = pipes[i]
        if not pipe.top or not pipe.top.Parent then
            table.remove(pipes, i)
            continue
        end
        
        local newX = pipe.x - pipeSpeed * dt
        pipe.x = newX
        pipe.top.Position = UDim2.new(0, newX, 0, pipe.top.Position.Y.Offset)
        pipe.bottom.Position = UDim2.new(0, newX, 0, pipe.bottom.Position.Y.Offset)
        
        -- Remove offscreen pipes
        if newX + pipeWidth < 0 then
            pipe.top:Destroy()
            pipe.bottom:Destroy()
            table.remove(pipes, i)
            continue
        end
        
        -- Score when passing pipe
        if not pipe.passed and newX + pipeWidth < bird.Position.X.Offset then
            pipe.passed = true
            score = score + 1
            ScoreLabel.Text = "SCORE: " .. score
            if score > bestScore then
                bestScore = score
                BestLabel.Text = "BEST: " .. bestScore
            end
        end
        
        -- Collision detection
        if gameActive then
            local birdX = bird.Position.X.Offset
            local birdY = bird.Position.Y.Offset
            local birdSizeX = bird.AbsoluteSize.X
            local birdSizeY = bird.AbsoluteSize.Y
            
            -- Check collision with top pipe
            if newX < birdX + birdSizeX and newX + pipeWidth > birdX then
                if birdY < pipe.top.Size.Y.Offset then
                    gameActive = false
                end
                -- Check collision with bottom pipe
                if birdY + birdSizeY > pipe.bottom.Position.Y.Offset then
                    gameActive = false
                end
            end
        end
    end
    
    -- Game over handling
    if not gameActive then
        -- Show game over text
        if not Canvas:FindFirstChild("GameOverText") then
            local gameOverText = Instance.new("TextLabel")
            gameOverText.Name = "GameOverText"
            gameOverText.Size = UDim2.new(1, 0, 1, 0)
            gameOverText.BackgroundTransparency = 1
            gameOverText.Text = "GAME OVER\nTap FLAP to restart"
            gameOverText.TextColor3 = Color3.fromRGB(255, 100, 100)
            gameOverText.TextSize = 14
            gameOverText.Font = Enum.Font.GothamBold
            gameOverText.TextWrapped = true
            gameOverText.ZIndex = 5
            gameOverText.Parent = Canvas
        end
    else
        local gameOverText = Canvas:FindFirstChild("GameOverText")
        if gameOverText then gameOverText:Destroy() end
    end
end

