-- Animated grid lines (moving)
local GridOverlay = Instance.new("Frame")
GridOverlay.Size = UDim2.new(1, 0, 1, 0)
GridOverlay.BackgroundTransparency = 1
GridOverlay.ZIndex = 2
GridOverlay.Parent = Background

local function createGridLines()
    local lines = {}
    for i = 0, 20 do
        local lineH = Instance.new("Frame")
        lineH.Size = UDim2.new(1, 0, 0, 1)
        lineH.Position = UDim2.new(0, 0, 0, i * 50)
        lineH.BackgroundColor3 = Color3.fromRGB(0, 200, 255)
        lineH.BackgroundTransparency = 0.85
        lineH.BorderSizePixel = 0
        lineH.ZIndex = 2
        lineH.Parent = GridOverlay
        
        local lineV = Instance.new("Frame")
        lineV.Size = UDim2.new(0, 1, 1, 0)
        lineV.Position = UDim2.new(0, i * 50, 0, 0)
        lineV.BackgroundColor3 = Color3.fromRGB(0, 200, 255)
        lineV.BackgroundTransparency = 0.85
        lineV.BorderSizePixel = 0
        lineV.ZIndex = 2
        lineV.Parent = GridOverlay
        
        table.insert(lines, {frame = lineH, axis = "H", offset = i * 50})
        table.insert(lines, {frame = lineV, axis = "V", offset = i * 50})
    end
    
    task.spawn(function()
        local t = 0
        while ScreenGui.Parent do
            t = t + 0.5
            for _, line in ipairs(lines) do
                if line.axis == "H" then
                    local newPos = (line.offset + t) % 100
                    line.frame.Position = UDim2.new(0, 0, 0, newPos)
                else
                    local newPos = (line.offset + t) % 100
                    line.frame.Position = UDim2.new(0, newPos, 0, 0)
                end
            end
            task.wait(0.05)
        end
    end)
end

task.spawn(createGridLines)

-- ========== DIGITAL RAIN (Neon Binary Stream) ==========
local RainContainer = Instance.new("Frame")
RainContainer.Size = UDim2.new(1, 0, 1, 0)
RainContainer.BackgroundTransparency = 1
RainContainer.ZIndex = 3
RainContainer.Parent = Background

local function createDigitalRain()
    local columns = math.floor(workspace.CurrentCamera.ViewportSize.X / 35)
    if columns > 35 then columns = 35 end
    local drops = {}
    
    for i = 1, columns do
        local stream = Instance.new("TextLabel")
        stream.Size = UDim2.new(0, 30, 1, 0)
        stream.Position = UDim2.new(0, i * 35, 0, math.random(-100, 0))
        stream.BackgroundTransparency = 1
        stream.Text = ""
        stream.TextColor3 = Color3.fromRGB(0, 200, 255)
        stream.TextSize = 14
        stream.Font = Enum.Font.Code
        stream.TextTransparency = 0.3
        stream.ZIndex = 3
        stream.Parent = RainContainer
        
        drops[i] = {
            label = stream,
            y = math.random(0, 100),
            speed = math.random(2, 6),
            chars = {}
        }
    end
    
    task.spawn(function()
        while ScreenGui.Parent do
            for i, drop in ipairs(drops) do
                drop.y = drop.y + drop.speed
                if drop.y > 100 then
                    drop.y = -15
                    drop.speed = math.random(2, 6)
                end
                drop.label.Position = UDim2.new(0, i * 35, 0, drop.y)
                
                local binText = ""
                for j = 1, 6 do
                    local char = math.random(0, 1) == 1 and "1" or "0"
                    if math.random(1, 10) == 1 then
                        char = string.char(math.random(65, 90))
                    end
                    binText = binText .. char .. " "
                end
                drop.label.Text = binText
            end
            task.wait(0.12)
        end
    end)
end

task.spawn(createDigitalRain)

