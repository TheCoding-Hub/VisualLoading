-- Game Logic Variables
local bird = nil
local pipes = {}
local score = 0
local bestScore = 0
local gameActive = true
local gravity = 800
local jumpForce = -250
local pipeSpeed = 120
local pipeGap = 90
local pipeWidth = 45
local pipeSpawnTimer = 0
local birdVelocity = 0

local function getCanvasSize()
    return Canvas.AbsoluteSize.Y > 0 and Canvas.AbsoluteSize or Vector2.new(300, 300)
end

local function createBird()
    if bird then bird:Destroy() end
    bird = Instance.new("Frame")
    bird.Size = UDim2.new(0, 20, 0, 20)
    bird.Position = UDim2.new(0.3, 0, 0.5, 0)
    bird.BackgroundColor3 = Color3.fromRGB(255, 200, 50)
    bird.ZIndex = 5
    bird.Parent = Canvas
    Instance.new("UICorner", bird).CornerRadius = UDim.new(1, 0)
    birdVelocity = 0
end

local function createPipePair()
    local cSize = getCanvasSize()
    local gapPos = math.random(40, cSize.Y - pipeGap - 40)
    
    local top = Instance.new("Frame")
    top.Size = UDim2.new(0, pipeWidth, 0, gapPos)
    top.Position = UDim2.new(1, 0, 0, 0)
    top.BackgroundColor3 = Color3.fromRGB(70, 40, 180)
    top.ZIndex = 4
    top.Parent = Canvas
    
    local bottom = Instance.new("Frame")
    bottom.Size = UDim2.new(0, pipeWidth, 0, cSize.Y - gapPos - pipeGap)
    bottom.Position = UDim2.new(1, 0, 0, gapPos + pipeGap)
    bottom.BackgroundColor3 = Color3.fromRGB(70, 40, 180)
    bottom.ZIndex = 4
    bottom.Parent = Canvas

    table.insert(pipes, {top = top, bottom = bottom, x = cSize.X, passed = false})
end

local function resetGame()
    for _, p in ipairs(pipes) do p.top:Destroy() p.bottom:Destroy() end
    pipes = {}
    score = 0
    ScoreLabel.Text = "SCORE: 0"
    createBird()
    pipeSpawnTimer = 0
    gameActive = true
    if Canvas:FindFirstChild("GameOver") then Canvas.GameOver:Destroy() end
end

local function flap()
    if not gameActive then resetGame() return end
    birdVelocity = jumpForce
end

local function updateGame(dt)
    if not gameActive or not bird then return end
    local cSize = getCanvasSize()
    
    birdVelocity = birdVelocity + (gravity * dt)
    local newY = bird.Position.Y.Offset + (birdVelocity * dt)
    
    if newY < 0 or newY > cSize.Y - 20 then
        gameActive = false
    end
    bird.Position = UDim2.new(0.3, 0, 0, newY)
    
    pipeSpawnTimer = pipeSpawnTimer + dt
    if pipeSpawnTimer > 1.8 then
        pipeSpawnTimer = 0
        createPipePair()
    end
    
    for i = #pipes, 1, -1 do
        local p = pipes[i]
        p.x = p.x - (pipeSpeed * dt)
        p.top.Position = UDim2.new(0, p.x, 0, 0)
        p.bottom.Position = UDim2.new(0, p.x, 0, p.top.Size.Y.Offset + pipeGap)
        
        if p.x + pipeWidth < 0 then
            p.top:Destroy() p.bottom:Destroy()
            table.remove(pipes, i)
        elseif p.x < (cSize.X * 0.3) + 20 and p.x + pipeWidth > (cSize.X * 0.3) then
            local bY = bird.Position.Y.Offset
            if bY < p.top.Size.Y.Offset or bY + 18 > p.top.Size.Y.Offset + pipeGap then
                gameActive = false
            end
        end
        
        if not p.passed and p.x < (cSize.X * 0.3) then
            p.passed = true
            score = score + 1
            ScoreLabel.Text = "SCORE: " .. score
            if score > bestScore then bestScore = score BestLabel.Text = "BEST: " .. bestScore end
        end
    end
    
    if not gameActive then
        local go = Instance.new("TextLabel")
        go.Name = "GameOver"
        go.Size = UDim2.new(1,0,1,0)
        go.Text = "GAME OVER\nTAP TO RESTART"
        go.TextColor3 = Color3.fromRGB(255, 50, 50)
        go.BackgroundTransparency = 1
        go.Font = Enum.Font.GothamBold
        go.ZIndex = 10
        go.Parent = Canvas
    end
end

FlapBtn.MouseButton1Click:Connect(flap)
RunService.Heartbeat:Connect(function(dt) updateGame(math.min(dt, 0.05)) end)
createBird()

